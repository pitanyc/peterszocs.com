// Portfolio modal old.peterszocs
#portfolioModalOldPeterSzocs.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase Old Personal Website
                            p.item-intro.text-muted This was my old personal website
                            img.img-fluid.d-block.mx-auto(src='assets/img/portfolio/old-peterszocs.png', alt='...')
                            p This was my first website. It features Resume, Photos, Music and Contact sections with a fully working contact form.
                            ul.list-inline
                                li
                                    strong Demo:
                                    a(target='_blank', href='https://old.szocs.info') https://old.szocs.info
                                li
                                    strong Source:
                                    a(target='_blank', href='https://github.com/pitanyc/old.peterszocs.com') https://github.com/pitanyc/old.peterszocs.com
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                | Close