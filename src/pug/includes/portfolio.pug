                            .portfolio-hover-content
                                i.fas.fa-plus.fa-3x
                        picture
                            source(srcset='assets/img/portfolio/chat.webp', type='image/webp')
                            img.img-fluid(src='assets/img/portfolio/chat-opt.png', alt='...')
                    .portfolio-caption
                        .portfolio-caption-heading Chat
                        .portfolio-caption-subheading.text-muted Feature rich chat application
