// Portfolio
section#portfolio.page-section.bg-light
    .container
        .text-center
            h2.section-heading.text-uppercase Portfolio
            h3.section-subheading.text-muted Explore some of my work on GitHub.
        .row
            .col-lg-4.col-sm-6.mb-5.portfolio-item
                // animated-header
                .portfolio-item
                    a.portfolio-link(data-bs-toggle='modal', href='#portfolioModalAnimatedHeader')
                        .portfolio-hover
                            .portfolio-hover-content
                                i.fas.fa-plus.fa-3x
                        picture
                            source(srcset='assets/img/portfolio/animated-header.webp', type='image/webp')
                            img.img-fluid(src='assets/img/portfolio/animated-header-opt.png', alt='...')
                    .portfolio-caption
                        .portfolio-caption-heading Animated Header
                        .portfolio-caption-subheading.text-muted Responsive on-scroll header component
            .col-lg-4.col-sm-6.mb-5.portfolio-item
                // cairo-chat
                .portfolio-item
                    a.portfolio-link(data-bs-toggle='modal', href='#portfolioModalChat')
